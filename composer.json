{
    "name": "pratiksahu2003/cashfree-sdk",
    "description": "A lightweight PHP SDK and Laravel package for the Cashfree Payment Gateway (PG v3 API).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "cashfree",
        "payment",
        "gateway",
        "sdk",
        "php",
        "laravel",
        "composer",
        "webhook",
        "refund"
    ],
    "authors": [
        {
            "name": "Pratik Sahu",
            "email": "pratiksahu1535@gmail.com",
            "homepage": "https://github.com/Pratiksahu2003"
        }
    ],
    "homepage": "https://github.com/Pratiksahu2003/cashfree-sdk",
    "support": {
        "issues": "https://github.com/Pratiksahu2003/cashfree-sdk/issues",
        "source": "https://github.com/Pratiksahu2003/cashfree-sdk"
    },
    "require": {
        "php": "^8.0",
        "composer-plugin-api": "^2.2",
        "guzzlehttp/guzzle": "^7.5",
        "psr/log": "^1.0 || ^2.0 || ^3.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "composer/composer": "^2.7",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "CashfreePayment\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CashfreePayment\\Tests\\": "tests/"
        }
    },
    "extra": {
        "class": "CashfreePayment\\Composer\\InstallPlugin",
        "laravel": {
            "providers": [
                "CashfreePayment\\CashfreePaymentServiceProvider"
            ],
            "aliases": {
                "Cashfree": "CashfreePayment\\Facades\\Cashfree"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
