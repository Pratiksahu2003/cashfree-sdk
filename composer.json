{
    "name": "pratiksahu1535/cashfree-payment",
    "description": "A lightweight PHP SDK for the Cashfree Payment Gateway (PG v3 API).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "cashfree",
        "payment",
        "gateway",
        "sdk",
        "php",
        "composer"
    ],
    "authors": [
        {
            "name": "Pratik Sahu",
            "email": "pratiksahu1535@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "guzzlehttp/guzzle": "^7.5",
        "psr/log": "^1.0 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "CashfreePayment\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CashfreePayment\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}